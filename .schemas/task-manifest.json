{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Akuity Intelligence task manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["slackChannel", "tasks"],
  "properties": {
    "slackChannel": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "title", "schedule", "context", "deliverTo", "owner"],
        "properties": {
          "file": { "type": "string" },
          "title": { "type": "string" },
          "schedule": { "type": "string" },
          "context": { "type": "string" },
          "deliverTo": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "channel"],
            "properties": {
              "kind": { "type": "string" },
              "channel": { "type": "string" }
            }
          },
          "owner": { "type": "string" }
        }
      }
    }
  }
}
